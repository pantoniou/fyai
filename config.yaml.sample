# fyai configuration (sample)
#
# Use it as:
#   $XDG_CONFIG_HOME/fyai/config.yaml   (user bootstrap file,
#                                        else ~/.config/fyai/config.yaml)
#   fyai init / fyai config import <file>   (repository: ingested into the
#                                            .fyai/arena container root)
# or pass any file explicitly with --config/-C (overlays the arena or bootstrap
# config; later --set deltas still take precedence).
# Edit the repository config in place with `fyai config edit`, inspect it
# with `fyai config export`. Individual keys can be poked from the command
# line with `--set <key[=value]>` / `--get <key>` / `--delete <key>` (or the
# matching `fyai config set|get|delete` subcommands); keys are slash paths,
# e.g. `fyai --set display/color=on`. Add `--transient` to keep a session's
# edits (and its conversation state) in memory only.
#
# There is one persisted configuration source: the arena config. The user file
# above is bootstrap-only: it becomes the base only when the arena has no
# config, and is never overlaid onto one. The merged document is, in order:
#   arena config (or user bootstrap) -> --config file -> --set deltas
# Built-in defaults back any key the merged document omits. The catalogue
# derives provider/url/grammar/wire-id read-only when the model resolves; those
# resolved values are not persisted as configuration intent.
#
# Every key below is set to its actual compiled-in default, explicitly -
# nothing is left to an invisible C-level default. Most run-shaping switches
# (temperature, reasoning, streaming, markdown rendering, stats, logprobs,
# obfuscation, ...) have no dedicated CLI flag at all; they are config keys
# only, poked via `config set` / `--set`. Stylistic options live under
# `display:`, logging controls under `logging:`.

# --- Model selection -------------------------------------------------------
#
# A single `model` key drives provider selection. The catalogue
# (`fyai catalog list`) maps the model to its canonical provider, endpoint
# URL, API grammar and provider wire-id. Prefix with `provider/` to pin a
# specific provider that also offers the model, e.g. `openrouter/glm-5.2`.
# Override on the command line with `--model`/`-m`.
model: gpt-5.4-mini

# `provider` is never a config key - it is derived read-only from `model` at
# resolve time and shown by `/model`, `/config`, `fyai catalog`, etc.

# API grammar: intent, not derived - responses | chat-completions | messages
api: responses

# `api_url` is derived from the catalogue by default; set explicitly only to
# override the endpoint the catalogue resolves for the current model/api.
# api_url: https://api.openai.com/v1/responses

# The API key is taken (in order) from `--api-key`/`-k`, the `api_key` env
# mapping below, or the provider's conventional environment variable:
# <PROVIDER>_API_KEY (OPENAI_API_KEY, ANTHROPIC_API_KEY, OPENROUTER_API_KEY,
# DEEPSEEK_API_KEY, GOOGLE_API_KEY...). Secrets are never written as raw values;
# reference an environment variable instead. No default - omitted here on purpose.
# api_key:
#   type: env
#   value: OPENAI_API_KEY

# --- Top-level defaults ----------------------------------------------------
system_prompt: You are a concise assistant.
temperature: 0
max_tool_iterations: 50
# Output-token cap per model call. Required by the Anthropic Messages API
# (sent on every request there); defaults from the catalogue otherwise.
max_tokens: 8192

# Reasoning / thinking effort for reasoning-capable models. Maps to the
# Responses API `reasoning: { effort, summary }` and to Chat Completions
# `reasoning_effort` (summary is Responses-only and ignored otherwise). No
# dedicated flag - `config set reasoning/effort high` / `--set
# reasoning/effort=high`. Default is unset (no reasoning requested) - there
# is no valid enum value for "off", so the key is absent rather than null.
# reasoning:
#   effort: medium      # minimal | low | medium | high
#   summary: auto       # auto | concise | detailed

tools: true
builtin_shell: true
# Landlock-confine shell-tool sub-executions (Linux only; no-op elsewhere):
# read-only system paths, read/write the project and temp dirs, everything else
# denied. Best-effort - the allow-list/prompt remains the portable floor when
# Landlock is unavailable. Either a bool (enable with defaults) or a mapping:
#   sandbox:
#     enabled: true
#     deny:                 # carved out of the project (the .fyai arena is
#       - secrets           # always denied); paths are project-relative,
#       - ~/.ssh            # absolute (/...), or ~-relative
#     allow:                # extra grants outside the project
#       - /opt/toolchain            # string => read/write (rw)
#       - { path: /ro/data, mode: ro }      # read + execute only
#       - { path: /src, mode: edit }        # modify existing, no create/delete
#       - { path: /logs, mode: append }     # write without truncating
#       # modes: rw (default) | ro | edit | append
#     network:              # present => restrict egress to these TCP ports
#       ports: [443]        # (omit `network` entirely to leave egress open;
#                           #  empty ports denies all egress)
# `fyai sandbox on` stores this canned policy:
# sandbox: { enabled: true, deny: [secrets, ~/.ssh], network: { ports: [443] } }
sandbox: false

logprobs: false
top_logprobs: -1
token_extents: false     # record streamed token extents in turn metadata
no_obfuscation: false
whitewash_api_keys: true # redact API keys in wire logs
response_chain: false    # chain via previous_response_id (Responses API
                          # only); off by default - a stale/evicted stored
                          # response hard-errors rather than degrading to
                          # full replay

# No default - computed at runtime (nearest .fyai walking up from cwd);
# override only to pin a specific arena location.
# arena_dir: /path/to/.fyai/arena

logging:
  wire: false
  stream: false
  conversation: false

# --- Display / theming ------------------------------------------------------
#
# All stylistic options are grouped here (this nested form is the only one).
display:
  markdown: true          # render markdown output
  stream: true             # stream the response
  tool_preview_lines: 5    # rendered rows of a tool result shown before it is bounded
  # How streamed markdown is rendered (only with markdown + stream):
  markdown_mode: line      # line (per line, default) | stream (redraw per chunk) | oneshot (at end)
  color: auto               # auto (colour iff a terminal) | off | on (force, even piped)
  theme: dark                # background: auto (probe terminal) | dark | light
  # libfymd4c embedded theme: default | catppuccin | kanagawa | solarized |
  # tokyonight (each also with a -borderless variant). Unset uses the library
  # default theme.
  # markdown_theme: default
  # Fenced-code syntax-highlight theme: a libfyts built-in name (default,
  # catppuccin, kanagawa, solarized, tokyonight, vscode, vscode-nvim) or a
  # path to a styling YAML. Default is unset (the theme's own code.theme).
  # code_theme: default
  # Override the theme's table border, independent of markdown_theme:
  # theme (follow the theme) | grid (force borders) | none (borderless).
  # table_border: theme
  # Separators (rendered as markdown, themed by the renderer). turn_separator
  # breaks turns in the history view ("---" => a themed rule, "" => blank line);
  # tool_separator is rendered before each tool result; section_separator sits
  # between streamed reasoning and the answer.
  turn_separator: "---"
  # tool_separator: ""
  # section_separator: ""
  # Interactive prompt bubble. prompt is the input marker; prompt_top and
  # prompt_bottom are {key} templates over the session vars (model, provider,
  # api, effort, summary, temp, ctx). prompt_bottom replaces the banner; empty
  # reproduces it. All may carry SGR colour escapes (e.g. "\e[36m{model}\e[0m").
  # prompt: "  > "
  # prompt_top: ""
  # prompt_bottom: " {model} · {provider} · {api}{effort}{summary}{temp}{ctx}"
  pretty: false           # pretty (YAML) debug dumps
  thinking: true           # display model reasoning/thinking output
  cache_info: false       # print provider cache info
  stats: false            # print session token usage to stderr
